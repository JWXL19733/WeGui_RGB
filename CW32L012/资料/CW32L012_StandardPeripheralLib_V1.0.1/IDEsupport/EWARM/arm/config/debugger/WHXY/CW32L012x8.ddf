
;; Architecture extensions
#include weak "../ARM/ARMv6-M-SYST.ddf"

;; Memory information ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
;; Used to define address zones within the ARM address space (Memory).
;;
;;   Name      may be almost anything
;;   AdrSpace  must be Memory
;;   StartAdr  start of memory block
;;   EndAdr    end of memory block
;;   AccType   type of access, read-only (R), read-write (RW) or SFR (W)

[Memory]
;;         Name             AdrSpace    StartAdr    EndAdr      AccType   Width
Memory =  OTP              Memory      0x00100760  0x00100775  R
Memory =  Factory          Memory      0x00100776  0x001007FF  R
Memory =  PeriphAPB1       Memory      0x40000000  0x400037FF  RW
Memory =  PeriphAPB2       Memory      0x40004000  0x40007FFF  RW
Memory =  PeriphAHB1       Memory      0x40020000  0x40023BFF  RW
Memory =  PeriphAHB2       Memory      0x48000000  0x480003FF  RW
Memory =  SystemSFR        Memory      0xE0000000  0xE00FFFFF  W
Memory =  Flash            Memory      0x00000000  0x0000FFFF  R
Memory =  RAM              Memory      0x20000000  0x20001FFF  RW

TrustedRanges = true
UseSfrFilter = true

[SfrInclude]
File = CW32L012.svd
